{
  "name": "@downloadx/cli",
  "version": "0.1.0",
  "description": "Daemon-based CLI for downloadx — parallel chunked downloads via Unix socket IPC.",
  "keywords": [
    "cli",
    "daemon",
    "download",
    "download-manager",
    "parallel-download",
    "chunked-download",
    "resume",
    "unix-socket",
    "ipc",
    "tui",
    "ndjson",
    "agent",
    "background",
    "speed-limit",
    "node"
  ],
  "homepage": "https://myniqx.dev/projects/downloadx",
  "bugs": {
    "url": "https://github.com/myniqx/downloadx/issues"
  },
  "license": "MIT",
  "author": "myniqx",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/myniqx/downloadx.git",
    "directory": "apps/cli"
  },
  "bin": {
    "downloadx": "dist/cli.js"
  },
  "files": [
    "dist/cli.js",
    "README.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target node --banner '#!/usr/bin/env node'",
    "dx": "node ./dist/cli.js",
    "dev": "bun run src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@downloadx/core": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}

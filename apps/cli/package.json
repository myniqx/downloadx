{
  "name": "@downloadx/cli",
  "version": "0.1.0",
  "description": "Daemon-based CLI for downloadx — parallel chunked downloads via Unix socket IPC.",
  "author": "myniqx",
  "license": "MIT",
  "homepage": "https://myniqx.dev/projects/downloadx",
  "repository": {
    "type": "git",
    "url": "https://github.com/myniqx/downloadx.git",
    "directory": "apps/cli"
  },
  "bugs": {
    "url": "https://github.com/myniqx/downloadx/issues"
  },
  "type": "module",
  "bin": {
    "downloadx": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "download",
    "download-manager",
    "cli",
    "daemon",
    "parallel-download"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@downloadx/core": "^0.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target node --banner '#!/usr/bin/env node'",
    "build:bin": "bun build src/cli.ts --compile --outfile dist/downloadx --target bun",
    "dx": "./dist/downloadx",
    "dev": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit"
  }
}

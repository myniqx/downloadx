{
  "name": "downloadx-cli",
  "version": "0.1.0",
  "description": "CLI for downloadx — daemon-based download manager with Unix socket IPC.",
  "type": "module",
  "bin": {
    "downloadx": "./dist/cli.js"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target bun --banner '#!/usr/bin/env bun'",
    "build:bin": "bun build src/cli.ts --compile --outfile dist/downloadx --target bun",
    "dev": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "dependencies": {
    "downloadx": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
